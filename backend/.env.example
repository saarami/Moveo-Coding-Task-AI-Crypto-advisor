# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Application
APP_NAME=AI Crypto Advisor
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173"]

# Database
# Local development (Docker maps host port 5433 → container 5432):
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/crypto_advisor
# When running via docker-compose, the backend container uses the service name:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/crypto_advisor

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs (Phase 8)
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
OPENROUTER_API_KEY=
